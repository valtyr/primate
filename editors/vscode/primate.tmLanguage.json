{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "primate",
  "scopeName": "source.primate",
  "fileTypes": ["prim"],
  "patterns": [
    { "include": "#file-doc" },
    { "include": "#doc-comment" },
    { "include": "#line-comment" },
    { "include": "#attribute" },
    { "include": "#namespace-decl" },
    { "include": "#enum-decl" },
    { "include": "#type-alias-decl" },
    { "include": "#const-decl" },
    { "include": "#values" }
  ],
  "repository": {
    "file-doc": {
      "match": "//!.*$",
      "name": "comment.block.documentation.primate"
    },
    "doc-comment": {
      "match": "///.*$",
      "name": "comment.block.documentation.primate"
    },
    "line-comment": {
      "match": "//.*$",
      "name": "comment.line.double-slash.primate"
    },
    "attribute": {
      "begin": "(@)([A-Za-z_][A-Za-z0-9_]*)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.attribute.primate" },
        "2": { "name": "entity.name.function.attribute.primate" }
      },
      "end": "(?=\\n|$)",
      "patterns": [
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#bool-keyword" },
        { "name": "variable.parameter.primate", "match": "[A-Za-z_][A-Za-z0-9_]*" }
      ]
    },
    "namespace-decl": {
      "begin": "\\b(namespace)\\b",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.namespace.primate" }
      },
      "end": "(?=\\n|$)",
      "patterns": [
        {
          "match": "[A-Za-z_][A-Za-z0-9_]*",
          "name": "entity.name.namespace.primate"
        },
        { "match": "::", "name": "punctuation.separator.namespace.primate" }
      ]
    },
    "enum-decl": {
      "begin": "\\b(enum)\\s+([A-Z][A-Za-z0-9_]*)",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.enum.primate" },
        "2": { "name": "entity.name.type.enum.primate" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.section.block.end.primate" }
      },
      "patterns": [
        { "include": "#doc-comment" },
        { "include": "#line-comment" },
        { "include": "#type-name" },
        { "include": "#values" },
        {
          "match": "\\b([A-Z][A-Za-z0-9_]*)\\b",
          "name": "variable.other.enummember.primate"
        },
        { "match": "[,:={}]", "name": "punctuation.primate" }
      ]
    },
    "type-alias-decl": {
      "match": "\\b(type)\\s+([A-Z][A-Za-z0-9_]*)\\s*(=)",
      "captures": {
        "1": { "name": "keyword.declaration.type.primate" },
        "2": { "name": "entity.name.type.alias.primate" },
        "3": { "name": "keyword.operator.assignment.primate" }
      }
    },
    "const-decl": {
      "match": "^\\s*([A-Za-z_][A-Za-z0-9_:<>?\\[\\] ,]*?)\\s+([A-Z][A-Z0-9_]*)\\s*(=)",
      "captures": {
        "1": { "name": "storage.type.primate", "patterns": [{ "include": "#type-name" }] },
        "2": { "name": "constant.other.primate" },
        "3": { "name": "keyword.operator.assignment.primate" }
      }
    },
    "type-name": {
      "patterns": [
        {
          "match": "\\b(i32|i64|u32|u64|f32|f64|bool|string|duration|bytes|regex|url|i8|i16|u8|u16)\\b",
          "name": "support.type.primitive.primate"
        },
        {
          "match": "\\b(array|optional|map|tuple)\\b(?=\\s*<)",
          "name": "support.type.builtin.primate"
        },
        {
          "match": "\\b([A-Z][A-Za-z0-9_]*)\\b",
          "name": "entity.name.type.primate"
        },
        { "match": "::", "name": "punctuation.separator.namespace.primate" },
        { "match": "[<>?\\[\\]]", "name": "punctuation.primate" }
      ]
    },
    "values": {
      "patterns": [
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#bool-keyword" },
        { "include": "#none-keyword" },
        { "include": "#enum-variant-ref" }
      ]
    },
    "string": {
      "patterns": [
        {
          "name": "string.quoted.raw.primate",
          "begin": "r(#*)\"",
          "end": "\"\\1"
        },
        {
          "name": "string.quoted.double.primate",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "match": "\\\\([nrt\"\\\\0])",
              "name": "constant.character.escape.primate"
            }
          ]
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "match": "\\b(0x[0-9A-Fa-f_]+|0b[01_]+|0o[0-7_]+)\\b",
          "name": "constant.numeric.integer.primate"
        },
        {
          "match": "\\b(\\d[\\d_]*\\.\\d[\\d_]*(?:[eE][+-]?\\d+)?)([A-Za-z]+)?\\b",
          "captures": {
            "1": { "name": "constant.numeric.float.primate" },
            "2": { "name": "keyword.unit.primate" }
          }
        },
        {
          "match": "\\b(\\d[\\d_]*)([A-Za-z]+)?\\b",
          "captures": {
            "1": { "name": "constant.numeric.integer.primate" },
            "2": { "name": "keyword.unit.primate" }
          }
        }
      ]
    },
    "bool-keyword": {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.boolean.primate"
    },
    "none-keyword": {
      "match": "\\bnone\\b",
      "name": "constant.language.null.primate"
    },
    "enum-variant-ref": {
      "match": "\\b([A-Z][A-Za-z0-9_]*)\\b",
      "name": "variable.other.enummember.primate"
    }
  }
}
